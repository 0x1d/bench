export API_TOKEN=1234567890
export API_BASE_URL=http://localhost:8080
# Optional: path to config file (default: config.yaml in project root)
# export BENCH_CONFIG=/path/to/config.yaml
# Optional: PostgreSQL connection string for database features (local or Supabase)
# Local: postgresql://bench:bench@localhost:5432/bench (run: docker compose up -d)
# export DATABASE_URL=postgresql://bench:bench@localhost:5432/bench
# Optional: Allow internal REST requests (localhost, private IPs) - required for agent in dev
# export BENCH_ALLOW_INTERNAL_REST=true
